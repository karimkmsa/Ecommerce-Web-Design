<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Cart - Brand</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/cart.css">
</head>

<body>
    <!-- Header -->
    <header class="header">
        <div class="header-top">
            <a href="/" class="logo">
                <div class="logo-icon">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <rect x="2" y="2" width="16" height="16" rx="3" fill="white" opacity="0.9" />
                        <path d="M6 8h8M6 11h5" stroke="#1a73e8" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                </div>
                <span class="logo-text">Brand</span>
            </a>

            <form class="search-bar" action="/products" method="GET">

                <input type="text" class="search-input" name="keyword" placeholder="Search" value="<%= keyword %>" />

                <div class="search-divider"></div>

                <select class="search-category" name="category">

                    <option value="">
                        All category
                    </option>

                    <option value="Electronics" <%=category==="Electronics" ? "selected" : "" %>
                        >
                        Electronics
                    </option>

                    <option value="fashion" <%=category==="fashion" ? "selected" : "" %>
                        >
                        fashion
                    </option>

                    <option value="Home" <%=category==="Home" ? "selected" : "" %>
                        >
                        Home
                    </option>

                </select>

                <button class="search-btn">
                    Search
                </button>

            </form>

            <nav class="header-icons">

                <% if (user) { %>
                    <a href="/profile" class="icon-link">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.5">
                            <circle cx="12" cy="8" r="4" />
                            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                        </svg>
                        <span>Profile</span>
                    </a>
                    <% } else { %>
                        <a href="/user/register" class="icon-link">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="1.5">
                                <circle cx="12" cy="8" r="4" />
                                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                            </svg>
                            <span>Profile</span>
                        </a>
                        <% } %>

                            <a href="#" class="icon-link">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="1.5">
                                    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
                                </svg>
                                <span>Message</span>
                            </a>
                            <a href="#" class="icon-link">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="1.5">
                                    <path
                                        d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                                </svg>
                                <span>Orders</span>
                            </a>
                            <a href="#" class="icon-link">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="1.5">
                                    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                                    <line x1="3" y1="6" x2="21" y2="6" />
                                    <path d="M16 10a4 4 0 01-8 0" />
                                </svg>
                                <span>My cart</span>
                            </a>
            </nav>
        </div>

        <div class="header-nav">
            <div class="nav-left">
                <a href="/products" class="nav-link nav-category">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <line x1="3" y1="12" x2="21" y2="12" />
                        <line x1="3" y1="18" x2="21" y2="18" />
                    </svg>
                    All category
                </a>
                <a href="#" class="nav-link">Hot offers</a>
                <a href="#" class="nav-link">Gift boxes</a>
                <a href="#" class="nav-link">Projects</a>
                <a href="#" class="nav-link">Menu item</a>
                <a href="#" class="nav-link nav-dropdown">Help
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="6 9 12 15 18 9" />
                    </svg>
                </a>
            </div>
            <div class="nav-right">
                <a href="#" class="nav-link nav-dropdown">English, USD
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="6 9 12 15 18 9" />
                    </svg>
                </a>
                <a href="#" class="nav-link nav-dropdown">Ship to 🇩🇪
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="6 9 12 15 18 9" />
                    </svg>
                </a>
            </div>
        </div>

    </header>
    <!-- Main Content -->
    <div class="main-container">
        <h1 class="page-title">
            My cart (<%= cart.products.length %>)
        </h1>
        <div class="cart-grid">
            <!-- Cart Items -->
            <div class="cart-items">

                <% cart.products.forEach(item=> { %>

                    <div class="cart-item">

                        <div class="item-image">

                            <img src="/uploads/<%= item.product.image %>" alt="<%= item.product.title %>">

                        </div>

                        <div class="item-details">

                            <h3 class="item-title">

                                <%= item.product.title %>

                            </h3>

                            <p class="item-info">

                                Category:
                                <%= item.product.category %>

                            </p>

                            <p class="item-info">

                                Stock:
                                <%= item.product.stock %>

                            </p>

                            <div class="item-actions">

                                <a href="javascript:void(0)" onclick="removeFromCart('<%= item.product._id %>')"
                                    class="action-link">

                                    Remove

                                </a>

                                <a href="#" class="action-link save">

                                    Save for later

                                </a>

                            </div>

                        </div>

                        <div>

                            <div class="item-price">

                                $<%= item.product.price * item.quantity %>

                            </div>

                            <div class="quantity-selector">

                                <!-- decrease -->

                                <button class="qty-btn" onclick="updateQty('<%= item.product._id %>', 'decrease')"
                                    <%=item.quantity <=1 ? 'disabled' : '' %>
                                    >
                                    <i class="fas fa-minus"></i>
                                </button>

                                <span class="qty-value">

                                    <%= item.quantity %>

                                </span>

                                <!-- increase -->

                                <button class="qty-btn" onclick="updateQty('<%= item.product._id %>', 'increase')"
                                    <%=item.quantity>= item.product.stock ? 'disabled' : '' %>
                                    >
                                    <i class="fas fa-plus"></i>
                                </button>

                            </div>

                        </div>

                    </div>

                    <% }) %>

            </div>

            <!-- Order Summary -->
            <div class="order-summary">
                <div class="coupon-section">
                    <div class="coupon-title">Have a coupon?</div>
                    <div class="coupon-input-group">
                        <input type="text" class="coupon-input" placeholder="Add coupon">
                        <button class="btn-apply">Apply</button>
                    </div>
                </div>
                <div class="summary-row">
                    <span class="summary-label">Subtotal:</span>
                    <span class="summary-value">
                        $<%= subtotal.toFixed(2) %>
                    </span>
                </div>

                <div class="summary-row">
                    <span class="summary-label">Discount:</span>
                    <span class="summary-value discount">
                        $<%= discount.toFixed(2) %>
                    </span>
                </div>

                <div class="summary-row">
                    <span class="summary-label">Tax:</span>
                    <span class="summary-value tax">
                        $<%= tax.toFixed(2) %>
                    </span>
                </div>

                <div class="summary-divider"></div>

                <div class="summary-total">
                    <span>Total:</span>
                    <span>
                        $<%= total.toFixed(2) %>
                    </span>
                </div>
                <button class="btn-checkout" onclick="checkout()">
                    Checkout
                </button>
                <div class="payment-methods">
                    <div class="payment-icon"><i class="fab fa-cc-visa"></i></div>
                    <div class="payment-icon"><i class="fab fa-cc-mastercard"></i></div>
                    <div class="payment-icon"><i class="fab fa-cc-amex"></i></div>
                    <div class="payment-icon"><i class="fab fa-cc-paypal"></i></div>
                    <div class="payment-icon"><i class="fab fa-cc-apple-pay"></i></div>
                </div>
            </div>
        </div>

        <!-- Cart Actions -->
        <div class="cart-actions">
            <a href="#" class="btn-back">
                <i class="fas fa-arrow-left"></i>
                Back to shop
            </a>
            <a href="#" class="btn-remove-all">Remove all</a>
        </div>

        <!-- Info Boxes -->
        <div class="info-boxes">
            <div class="info-box">
                <div class="info-icon">
                    <i class="fas fa-lock"></i>
                </div>
                <div class="info-text">
                    <h4>Secure payment</h4>
                    <p>Have you ever finally just</p>
                </div>
            </div>
            <div class="info-box">
                <div class="info-icon">
                    <i class="fas fa-headset"></i>
                </div>
                <div class="info-text">
                    <h4>Customer support</h4>
                    <p>Have you ever finally just</p>
                </div>
            </div>
            <div class="info-box">
                <div class="info-icon">
                    <i class="fas fa-truck"></i>
                </div>
                <div class="info-text">
                    <h4>Free delivery</h4>
                    <p>Have you ever finally just</p>
                </div>
            </div>
        </div>

        <!-- Saved for Later -->
        <div class="saved-section">
            <h2 class="section-title">Saved for later</h2>
            <div class="saved-grid">

                <div class="saved-item">
                    <div class="saved-image">
                        <img src="" alt="" style="max-width: 100%; max-height: 100%; object-fit: contain;">
                    </div>
                    <div class="saved-price">
                    </div>
                    <div class="saved-title">

                    </div>
                    <button class="btn-move-cart">
                        <i class="fas fa-shopping-cart"></i>
                        Move to cart
                    </button>
                </div>
            </div>
        </div>

        <!-- Promo Banner -->
        <div class="promo-banner">
            <div class="promo-content">
                <h3>Super discount on more than 100 USD</h3>
                <p>Have you ever finally just write dummy info</p>
            </div>
            <button class="btn-shop-now">Shop now</button>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <div class="logo">
                        <div class="logo-icon">
                            <i class="fas fa-cube"></i>
                        </div>
                        Brand
                    </div>
                    <p>Best information about the company goes here but now lorem ipsum is</p>
                </div>

                <div class="footer-column">
                    <h4>About</h4>
                    <ul>
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Find store</a></li>
                        <li><a href="#">Categories</a></li>
                        <li><a href="#">Blogs</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>Partnership</h4>
                    <ul>
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Find store</a></li>
                        <li><a href="#">Categories</a></li>
                        <li><a href="#">Blogs</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>Information</h4>
                    <ul>
                        <li><a href="#">Help Center</a></li>
                        <li><a href="#">Money Refund</a></li>
                        <li><a href="#">Shipping</a></li>
                        <li><a href="#">Contact us</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>For users</h4>
                    <ul>
                        <li><a href="#">Login</a></li>
                        <li><a href="#">Register</a></li>
                        <li><a href="#">Settings</a></li>
                        <li><a href="#">My Orders</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4>Get app</h4>
                    <div class="app-buttons">
                        <a href="#" class="app-btn">
                            <i class="fab fa-apple"></i>
                            <div>
                                <div style="font-size: 0.75rem;">Download on the</div>
                                <div style="font-weight: 700;">App Store</div>
                            </div>
                        </a>
                        <a href="#" class="app-btn">
                            <i class="fab fa-google-play"></i>
                            <div>
                                <div style="font-size: 0.75rem;">GET IT ON</div>
                                <div style="font-weight: 700;">Google Play</div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

            <div class="footer-bottom">
                <div class="copyright">© 2023 Ecommerce.</div>
                <div class="language-selector">
                    <img src="https://flagcdn.com/w20/us.png" alt="US">
                    <span>English</span>
                    <i class="fas fa-chevron-up"></i>
                </div>
            </div>
        </div>
    </footer>

    <script>

        async function updateQty(productId, action) {

            try {

                const response = await fetch(`/cart/update/${productId}`, {

                    method: "PATCH",

                    headers: {
                        "Content-Type": "application/json"
                    },

                    body: JSON.stringify({ action })

                });

                const data = await response.json();

                if (response.ok) {

                    location.reload();

                } else {

                    alert(data.message);

                }

            } catch (error) {

                console.log(error);

            }

        }
        async function removeFromCart(productId) {

            try {

                const res = await fetch(`/cart/remove/${productId}`, {
                    method: "DELETE"
                });

                const data = await res.json();

                if (res.ok) {
                    location.reload();
                } else {
                    alert(data.message);
                }

            } catch (err) {
                console.log(err);
            }
        }
        async function checkout() {

            try {


                const res = await fetch("/order/checkout", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    }
                });

                const data = await res.json();

                if (res.ok) {
                    alert("Order placed successfully");
                    window.location.href = "/";
                } else {
                    alert(data.message);
                }


            } catch (err) {
                console.log(err);
            }
        }
    </script>
</body>

</html>