  <script>
    function switchTab(id, btn) {
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.getElementById('tab-' + id).classList.add('active');
      btn.classList.add('active');
    }
    function selectThumb(el) {
      document.querySelectorAll('.detail-thumb').forEach(t => t.classList.remove('active'));
      el.classList.add('active');
    }
    document.querySelectorAll('.tier-item').forEach(function (item) {
      item.addEventListener('click', function () {
        document.querySelectorAll('.tier-item').forEach(t => t.classList.remove('active'));
        this.classList.add('active');
      });
    });


    async function addToCart(productId) {

      try {

        const res = await fetch("/cart/add", {

          method: "POST",

          headers: {
            "Content-Type": "application/json"
          },

          body: JSON.stringify({
            productId
          })

        });

        const data = await res.json();

        alert(data.message);

      } catch (error) {

        console.log(error);

      }

    }

    function buyNow(productId) {

      window.location.href = `/checkout/${productId}`;

    }
    document
    document.addEventListener("DOMContentLoaded", () => {

      const form = document.getElementById("reviewForm");
      const stars = document.querySelectorAll(".star");
      const ratingInput = document.getElementById("rating");
      const commentInput = document.getElementById("comment");

      // ⭐ Star rating logic
      stars.forEach((star) => {
        star.addEventListener("click", () => {
          const value = Number(star.dataset.value);
          ratingInput.value = value;

          stars.forEach((s) => {
            const starValue = Number(s.dataset.value);
            s.classList.toggle("active", starValue <= value);
          });
        });
      });

      // 🚀 Submit review
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        try {
          const rating = Number(ratingInput.value);
          const comment = commentInput.value.trim();

          if (!rating) {
            alert("Please select a rating");
            return;
          }

          if (!comment) {
            alert("Please write a comment");
            return;
          }

          const res = await fetch(`/products/<%= product._id %>/review`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify({ rating, comment })
          });

          const data = await res.json();

          alert(data.message);

          if (res.ok) {
            location.reload();
          }

        } catch (error) {
          console.log(error);
        }
      });

    });
  </script>

