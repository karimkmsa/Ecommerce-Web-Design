              Add Product
            </button>
          </div>
        </div>

        <!-- Table -->
        <table class="products-table" id="productsTable">
          <thead>
            <tr>
              <th><input type="checkbox" class="tbl-checkbox" id="checkAll" onchange="toggleAll(this)" /></th>
              <th>Product</th>
              <th>Category</th>
              <th>Price</th>
              <th>Stock</th>
              <th>Status</th>
              <th>Actions</th>
