          </div>
          <div>
            <div class="stat-value" id="statLowStock">0</div>
            <div class="stat-label">Low Stock</div>
          </div>
          <div class="stat-trend down">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 9 12 15 6 9"/></svg>
            -3%
