  <!-- ════════════════════════════════
       ADD / EDIT MODAL
  ════════════════════════════════════ --> 
<!-- ════════════════════════════════
     ADD / EDIT MODAL
════════════════════════════════ -->
<div class="modal-overlay" id="formModal">

  <div class="modal-box">

    <!-- Header -->
    <div class="modal-head">

      <h2 class="modal-title" id="formModalTitle">
        Add New Product
      </h2>

      <button 
        type="button"
        class="modal-close" 
        onclick="closeModal('formModal')"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

    </div>

    <!-- FORM -->
    <form 
      id="productForm"
      action="/dashboard/add-product"
      method="POST"
    >

      <!-- hidden id for edit -->
      <input type="hidden" name="_id" id="productId" />

      <div class="modal-body">

        <!-- Image Upload -->
        <div class="modal-field">

          <label>Product Image</label>

          <div 
            class="img-upload-area" 
            id="uploadArea" 
            onclick="document.getElementById('imgFile').click()"
            ondragover="event.preventDefault();this.classList.add('dragover')"
            ondragleave="this.classList.remove('dragover')"
            ondrop="handleDrop(event)"
          >

            <input 
              type="file" 
              id="imgFile" 
              accept="image/*" 
              onchange="previewImage(event)" 
            />

            <div class="img-upload-icon">

              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>

            </div>

            <p class="img-upload-text">
              <span>Click to upload</span> or drag & drop
            </p>

            <p class="img-upload-text" style="font-size:11px;color:#bbb;margin-top:4px;">
              PNG, JPG, GIF up to 10MB
            </p>

            <img id="imgPreview" class="img-preview" alt="Preview" />

          </div>

          <!-- image url -->
          <input 
            type="text"
            name="image"
            id="fieldImage"
            class="modal-input"
            placeholder="Paste image URL"
          />

        </div>

        <!-- Product Name -->
        <div class="modal-field">

          <label for="fieldName">
            Product Name <span>*</span>
          </label>

          <input 
            type="text" 
            id="fieldName" 
            name="name"
            class="modal-input" 
            placeholder="e.g. Nike Air Max 2024" 
          />

          <span class="auth-error-msg" id="errName">
            Product name is required.
          </span>

        </div>

        <!-- Price + Category -->
        <div class="modal-field-row">

          <div class="modal-field">

            <label for="fieldPrice">
              Price (USD) <span>*</span>
            </label>

            <input 
              type="number" 
              id="fieldPrice" 
              name="price"
              class="modal-input" 
              placeholder="0.00" 
              min="0" 
              step="0.01" 
            />

            <span class="auth-error-msg" id="errPrice">
              Enter a valid price.
            </span>

          </div>

          <div class="modal-field">

            <label for="fieldCategory">
              Category <span>*</span>
            </label>

            <select 
              id="fieldCategory" 
              name="category"
              class="modal-select"
            >

              <option value="">
                Select category
              </option>

              <option value="electronics">
                Electronics
              </option>

              <option value="fashion">
                Fashion
              </option>

              <option value="sports">
                Sports
              </option>

            </select>

            <span class="auth-error-msg" id="errCategory">
              Select a category.
            </span>

          </div>

        </div>

        <!-- Stock -->
        <div class="modal-field">

          <label for="fieldStock">
            Stock Quantity <span>*</span>
          </label>

          <input 
            type="number" 
            id="fieldStock" 
            name="stock"
            class="modal-input" 
            placeholder="0" 
            min="0" 
          />

          <span class="auth-error-msg" id="errStock">
            Enter a valid stock quantity.
          </span>

        </div>

        <!-- Description -->
        <div class="modal-field">

          <label for="fieldDesc">
            Description
          </label>

          <textarea 
            id="fieldDesc" 
            name="description"
            class="modal-textarea" 
            placeholder="Describe the product…"
          ></textarea>

        </div>

      </div>

      <!-- Footer -->
      <div class="modal-footer">

        <button 
          type="button"
          class="btn-cancel" 
          onclick="closeModal('formModal')"
        >
          Cancel
        </button>

        <button 
          type="submit"
          class="btn-save"
        >
          Save Product
        </button>

      </div>

    </form>

  </div>

</div>
<script>// ─── ADD ────────────────────────────────
function openAddModal() {

  document.getElementById('formModalTitle').textContent =
    'Add New Product';

  document.getElementById('productForm').action =
    '/dashboard/add-product';

  document.getElementById('productId').value = '';

  clearForm();

  openModal('formModal');
}


// ─── EDIT ───────────────────────────────
function openEdit(id) {

  const p = products.find(x => x.id === id);

  document.getElementById('formModalTitle').textContent =
    'Edit Product';

  document.getElementById('productForm').action =
    '/dashboard/update-product';

  document.getElementById('productId').value = p.id;

  document.getElementById('fieldName').value =
    p.name;

  document.getElementById('fieldPrice').value =
    p.price;

  document.getElementById('fieldCategory').value =
    p.category;

  document.getElementById('fieldStock').value =
    p.stock;

  document.getElementById('fieldDesc').value =
    p.description;

  document.getElementById('fieldImage').value =
    p.image || '';

  const preview = document.getElementById('imgPreview');

  if (p.image) {
    preview.src = p.image;
    preview.style.display = 'block';
  } else {
    preview.style.display = 'none';
  }

  openModal('formModal');
}


// ─── DELETE ─────────────────────────────
function openDelete(id) {

  deletingId = id;

  const p = products.find(x => x.id === id);

  document.getElementById('deleteName').textContent =
    `"${p.name}"`;

  openModal('deleteModal');
}

function confirmDelete() {

  window.location.href =
    `/dashboard/delete-product/${deletingId}`;
}</script>
