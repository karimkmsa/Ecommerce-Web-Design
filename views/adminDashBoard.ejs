  <!-- ════════════════════════════════
       DELETE CONFIRM MODAL
  ════════════════════════════════════ -->
  <div class="modal-overlay" id="deleteModal">
    <div class="modal-box" style="max-width:420px">
      <div class="modal-head">
        <h2 class="modal-title">Confirm Delete</h2>
        <button class="modal-close" onclick="closeModal('deleteModal')">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="modal-body" style="text-align:center;padding:28px 24px;">
        <div class="delete-modal-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        </div>
        <div class="delete-modal-title">Delete Product?</div>
        <p class="delete-modal-sub">Are you sure you want to delete <strong id="deleteName"></strong>? This action cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button class="btn-cancel" onclick="closeModal('deleteModal')">Cancel</button>
        <button class="btn-delete-confirm" onclick="confirmDelete()">Yes, Delete</button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="admin-toast" id="toast">
    <div class="toast-icon success" id="toastIcon">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
    </div>
    <span id="toastMsg">Product saved successfully!</span>
  </div>

  <script>
    // ─── DATA ───────────────────────────────
    const CATEGORY_EMOJIS = { electronics: '💻', fashion: '👕', sports: '⚽' };

    let products = [
      { id: 1, name: 'Canon Camera EOS 2000', price: 998, category: 'electronics', description: 'Professional DSLR camera with 10x optical zoom and 24MP sensor.', stock: 45, image: '' },
      { id: 2, name: 'Nike Air Max 2024',     price: 149, category: 'sports',      description: 'Lightweight running shoes with responsive foam cushioning.', stock: 120, image: '' },
      { id: 3, name: 'Slim Fit Cotton T-Shirt', price: 29, category: 'fashion',   description: 'Premium cotton slim-fit t-shirt available in multiple colours.', stock: 5,  image: '' },
      { id: 4, name: 'Sony WH-1000XM5',       price: 349, category: 'electronics', description: 'Industry-leading noise cancelling wireless headphones.', stock: 0,  image: '' },
      { id: 5, name: 'Adidas Running Shorts',  price: 49,  category: 'sports',     description: 'Breathable quick-dry shorts for high-intensity workouts.', stock: 78, image: '' },
      { id: 6, name: 'Leather Biker Jacket',   price: 189, category: 'fashion',    description: 'Classic genuine leather jacket with zip pockets.', stock: 12, image: '' },
    ];
    let nextId = 7;
    let editingId = null;
    let deletingId = null;
    let viewingId  = null;

    // ─── RENDER ─────────────────────────────
    function getStockBadge(stock) {
      if (stock === 0)   return `<span class="stock-badge no-stock"><span class="stock-dot"></span>Out of stock</span>`;
      if (stock <= 10)   return `<span class="stock-badge low-stock"><span class="stock-dot"></span>Low stock</span>`;
      return `<span class="stock-badge in-stock"><span class="stock-dot"></span>In stock</span>`;
    }

    function renderTable(list) {
      const tbody = document.getElementById('tableBody');
      if (list.length === 0) {
        tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;padding:40px;color:#bbb;">No products found.</td></tr>`;
        return;
      }
      tbody.innerHTML = list.map(p => `
        <tr>
          <td><input type="checkbox" class="tbl-checkbox row-check" data-id="${p.id}" /></td>
          <td>
            <div class="product-cell">
              <div class="product-thumb">
                ${p.image ? `<img src="${p.image}" alt="${p.name}" />` : CATEGORY_EMOJIS[p.category] || '📦'}
              </div>
              <div>
                <div class="product-cell-name" title="${p.name}">${p.name}</div>
                <div class="product-cell-id">#PRD-${String(p.id).padStart(4,'0')}</div>
              </div>
            </div>
          </td>
          <td><span class="cat-badge ${p.category}">${p.category.charAt(0).toUpperCase()+p.category.slice(1)}</span></td>
          <td><strong>$${Number(p.price).toFixed(2)}</strong></td>
          <td>${p.stock}</td>
          <td>${getStockBadge(p.stock)}</td>
          <td>
            <div class="row-actions">
              <button class="row-btn view-btn-row" title="View" onclick="openView(${p.id})">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
              <button class="row-btn edit-btn-row" title="Edit" onclick="openEdit(${p.id})">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              <button class="row-btn delete-btn-row" title="Delete" onclick="openDelete(${p.id})">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
              </button>
            </div>
          </td>
        </tr>
      `).join('');
      updateStats();
    }

    function updateStats() {
      const total   = products.length;
      const inStock  = products.filter(p => p.stock > 10).length;
      const lowStock = products.filter(p => p.stock > 0 && p.stock <= 10).length;
      const outStock = products.filter(p => p.stock === 0).length;
      document.getElementById('statTotal').textContent    = total;
      document.getElementById('statInStock').textContent  = inStock;
      document.getElementById('statLowStock').textContent = lowStock;
      document.getElementById('statOutStock').textContent = outStock;
      document.getElementById('sidebarCount').textContent = total;
      document.getElementById('tableCount').textContent   = `(${total} items)`;
      document.getElementById('tableInfo').textContent    = `Showing 1–${total} of ${total} products`;
    }

    function filterProducts() {
      const q   = (document.getElementById('tableSearch').value || document.getElementById('topbarSearch').value || '').toLowerCase();
      const cat = document.getElementById('catFilter').value;
      const filtered = products.filter(p =>
        (!q   || p.name.toLowerCase().includes(q) || p.description.toLowerCase().includes(q)) &&
        (!cat || p.category === cat)
      );
      renderTable(filtered);
      document.getElementById('tableInfo').textContent = `Showing 1–${filtered.length} of ${products.length} products`;
    }

    // ─── ADD ────────────────────────────────
    function openAddModal() {
      editingId = null;
      document.getElementById('formModalTitle').textContent = 'Add New Product';
      clearForm();
      openModal('formModal');
    }

    // ─── EDIT ───────────────────────────────
    function openEdit(id) {
      editingId = id;
      const p = products.find(x => x.id === id);
      document.getElementById('formModalTitle').textContent = 'Edit Product';
      document.getElementById('fieldName').value     = p.name;
      document.getElementById('fieldPrice').value    = p.price;
      document.getElementById('fieldCategory').value = p.category;
      document.getElementById('fieldStock').value    = p.stock;
      document.getElementById('fieldDesc').value     = p.description;
      document.getElementById('fieldImage').value    = p.image || '';
      const preview = document.getElementById('imgPreview');
      if (p.image) { preview.src = p.image; preview.style.display = 'block'; }
      else { preview.style.display = 'none'; }
      clearErrors();
      openModal('formModal');
    }

    // ─── SAVE ───────────────────────────────
    function saveProduct() {
      const name     = document.getElementById('fieldName').value.trim();
      const price    = parseFloat(document.getElementById('fieldPrice').value);
      const category = document.getElementById('fieldCategory').value;
      const stock    = parseInt(document.getElementById('fieldStock').value);
      const desc     = document.getElementById('fieldDesc').value.trim();
      const image    = document.getElementById('fieldImage').value;

      clearErrors();
      let valid = true;
      if (!name)               { showError('errName', 'fieldName');      valid = false; }
      if (isNaN(price)||price<0){ showError('errPrice', 'fieldPrice');   valid = false; }
      if (!category)           { showError('errCategory','fieldCategory'); valid = false; }
      if (isNaN(stock)||stock<0){ showError('errStock', 'fieldStock');   valid = false; }
      if (!valid) return;

      if (editingId) {
        const idx = products.findIndex(p => p.id === editingId);
        products[idx] = { id: editingId, name, price, category, description: desc, stock, image };
        showToast('Product updated successfully!', 'success');
      } else {
        products.unshift({ id: nextId++, name, price, category, description: desc, stock, image });
        showToast('Product added successfully!', 'success');
      }
      closeModal('formModal');
      renderTable(products);
    }

    // ─── VIEW ───────────────────────────────
    function openView(id) {
      viewingId = id;
      const p = products.find(x => x.id === id);
      document.getElementById('viewImg').innerHTML = p.image
        ? `<img src="${p.image}" alt="${p.name}" />`
        : `<span style="font-size:56px">${CATEGORY_EMOJIS[p.category]||'📦'}</span>`;
      document.getElementById('viewName').textContent  = p.name;
      document.getElementById('viewCat').innerHTML     = `<span class="cat-badge ${p.category}">${p.category.charAt(0).toUpperCase()+p.category.slice(1)}</span>`;
      document.getElementById('viewPrice').textContent = `$${Number(p.price).toFixed(2)}`;
      document.getElementById('viewStock').innerHTML   = `${p.stock} units &nbsp;${p.stock===0?'<span style="color:#e53935">●</span>':p.stock<=10?'<span style="color:#fb8c00">●</span>':'<span style="color:#43a047">●</span>'}`;
      document.getElementById('viewDesc').textContent  = p.description || '—';
      openModal('viewModal');
    }
    function editFromView() { closeModal('viewModal'); openEdit(viewingId); }

    // ─── DELETE ─────────────────────────────
    function openDelete(id) {
      deletingId = id;
      const p = products.find(x => x.id === id);
      document.getElementById('deleteName').textContent = `"${p.name}"`;
      openModal('deleteModal');
    }
    function confirmDelete() {
      products = products.filter(p => p.id !== deletingId);
      closeModal('deleteModal');
      renderTable(products);
      showToast('Product deleted.', 'error');
    }

    // ─── MODAL HELPERS ──────────────────────
    function openModal(id)  { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }

    // Close modal on overlay click
    document.querySelectorAll('.modal-overlay').forEach(el => {
      el.addEventListener('click', function(e) {
        if (e.target === this) closeModal(this.id);
      });
    });

    // ─── FORM HELPERS ───────────────────────
    function clearForm() {
      ['fieldName','fieldPrice','fieldCategory','fieldStock','fieldDesc','fieldImage'].forEach(id => {
        document.getElementById(id).value = '';
      });
      document.getElementById('imgPreview').style.display = 'none';
      clearErrors();
    }
    function clearErrors() {
      ['errName','errPrice','errCategory','errStock'].forEach(id => {
        document.getElementById(id).style.display = 'none';
      });
      ['fieldName','fieldPrice','fieldCategory','fieldStock'].forEach(id => {
        document.getElementById(id).classList.remove('has-error');
      });
    }
    function showError(errId, inputId) {
      document.getElementById(errId).style.display = 'block';
      document.getElementById(inputId).classList.add('has-error');
    }

    // ─── IMAGE PREVIEW ──────────────────────
    function previewImage(e) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function(ev) {
        const preview = document.getElementById('imgPreview');
        preview.src = ev.target.result;
        preview.style.display = 'block';
        document.getElementById('fieldImage').value = ev.target.result;
      };
      reader.readAsDataURL(file);
    }
    function handleDrop(e) {
      e.preventDefault();
      document.getElementById('uploadArea').classList.remove('dragover');
      const file = e.dataTransfer.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function(ev) {
        const preview = document.getElementById('imgPreview');
        preview.src = ev.target.result;
        preview.style.display = 'block';
        document.getElementById('fieldImage').value = ev.target.result;
      };
      reader.readAsDataURL(file);
    }

    // ─── TOAST ──────────────────────────────
    function showToast(msg, type = 'success') {
      const toast = document.getElementById('toast');
      const icon  = document.getElementById('toastIcon');
      document.getElementById('toastMsg').textContent = msg;
      icon.className = `toast-icon ${type}`;
      icon.innerHTML = type === 'success'
        ? `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>`
        : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>`;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }

    // ─── SIDEBAR TOGGLE ─────────────────────
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('collapsed');
      document.getElementById('adminMain').classList.toggle('expanded');
    }

    // ─── SELECT ALL ─────────────────────────
    function toggleAll(cb) {
      document.querySelectorAll('.row-check').forEach(c => c.checked = cb.checked);
    }

    // ─── INIT ───────────────────────────────
    renderTable(products);
  </script>

</body>
</html>