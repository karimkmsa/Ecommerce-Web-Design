  <script>
    let totalSecs = 4 * 86400 + 13 * 3600 + 34 * 60 + 56;
    function pad(n) { return String(n).padStart(2, '0'); }
    function tick() {
      if (totalSecs <= 0) return;
      totalSecs--;
      document.getElementById('days').textContent  = pad(Math.floor(totalSecs / 86400));
      document.getElementById('hours').textContent = pad(Math.floor((totalSecs % 86400) / 3600));
      document.getElementById('mins').textContent  = pad(Math.floor((totalSecs % 3600) / 60));
      document.getElementById('secs').textContent  = pad(totalSecs % 60);
    }
    setInterval(tick, 1000);
  </script>

