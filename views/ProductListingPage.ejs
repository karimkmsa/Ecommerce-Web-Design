        <div class="filter-group-body">
          <input type="range" class="price-range" min="0" max="99999" value="50000" id="priceRange" />
          <div class="price-inputs">
            <div class="price-input-group"><label>Min</label><input type="text" class="price-box" value="0"
                id="priceMin" /></div>
            <div class="price-input-group"><label>Max</label><input type="text" class="price-box" value="50000"
