    <div class="results-panel">
      <div class="results-toolbar">
        <div class="results-info">
          <span class="results-count"><strong>12,911 items</strong> in Mobile accessory</span>
          <label class="verified-toggle">
            <input type="checkbox" checked id="verifiedCheck" />
            <span class="toggle-slider"></span>
            <span>Verified only</span>
          </label>
        </div>
        <div class="results-controls">
          <select class="sort-select">
            <option>Featured</option>
            <option>Price: Low to High</option>
            <option>Price: High to Low</option>
            <option>Newest</option>
          </select>
          <div class="view-toggle">
            <button class="view-btn active" id="btnGrid" title="Grid view" onclick="setView('grid')">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7" />
                <rect x="14" y="3" width="7" height="7" />
                <rect x="3" y="14" width="7" height="7" />
                <rect x="14" y="14" width="7" height="7" />
              </svg>
            </button>
            <button class="view-btn" id="btnList" title="List view" onclick="setView('list')">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="8" y1="6" x2="21" y2="6" />
                <line x1="8" y1="12" x2="21" y2="12" />
                <line x1="8" y1="18" x2="21" y2="18" />
                <line x1="3" y1="6" x2="3.01" y2="6" />
                <line x1="3" y1="12" x2="3.01" y2="12" />
                <line x1="3" y1="18" x2="3.01" y2="18" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div class="products-container grid-view" id="productsContainer">



        <% allproducts.forEach(product=> { %>

          <div class="product-item">

            <div class="product-item-img">

              <img src="/uploads/<%= product.image %>" alt="<%= product.name %>">
              <button class="wishlist-btn" title="Add to wishlist">

                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path
                    d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
                </svg>

              </button>

            </div>

            <div class="product-item-info">

              <div class="product-price-row">

                <span class="product-price">

                  $<%= product.price %>

                </span>

              </div>

              <p class="product-name">

                <%= product.name %>

              </p>

              <div class="product-meta">

                <span class="product-shipping free-ship">

                  Free Shipping

                </span>

              </div>

              <p class="product-desc">

                <%= product.description %>

              </p>

              <a href="/products/<%= product._id %>">

                View Details

              </a>

            </div>

          </div>

          <% }) %>
      </div>



      <div class="pagination">

        <div class="show-per-page">

          <label>Show</label>

          <select class="per-page-select">

            <option>4</option>
            <option>8</option>
            <option>12</option>

          </select>

        </div>


        <div class="page-nums">

          <% if(currentPage> 1){ %>

            <a href="?page=<%= currentPage - 1 %>">

              <button class="page-btn">
                &lsaquo;
              </button>

            </a>

            <% } %>


              <% for(let i=1; i <=totalPages; i++){ %>

                <a href="?page=<%= i %>">

                  <button class="page-num <%= currentPage === i ? 'active' : '' %>">

                    <%= i %>

                  </button>

                </a>

                <% } %>


                  <% if(currentPage < totalPages){ %>

                    <a href="?page=<%= currentPage + 1 %>">

                      <button class="page-btn">
                        &rsaquo;
                      </button>

                    </a>

                    <% } %>

        </div>

      </div>

      <div class="newsletter-wrap">
        <h2>Subscribe on our newsletter</h2>
        <p>Get daily news on upcoming offers from many suppliers all over the world</p>
        <div class="newsletter-form">
          <div class="newsletter-input-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="1.5">
