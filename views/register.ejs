<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In / Register – Brand Store</title>
    <style>
        /* ── Auth page overrides ── */
        .auth-page {
            background: #f0f2f5;
        }

        /* Full centred layout (no split) */
        .auth-center {
            min-height: calc(90vh - 108px);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Card that holds BOTH forms */
        .auth-card {
            width: 100%;
            max-width: 980px;
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.10);
            overflow: hidden;
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 640px;
        }

        /* ── Left brand panel ── */
        .auth-brand-panel {
            background: linear-gradient(145deg, #1a73e8 0%, #0d47a1 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 48px 44px;
            position: relative;
            overflow: hidden;
        }

        .auth-brand-panel::before {
            content: '';
            position: absolute;
            width: 340px;
            height: 340px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.05);
            top: -80px;
            right: -100px;
        }

        .auth-brand-panel::after {
            content: '';
            position: absolute;
            width: 240px;
            height: 240px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.04);
            bottom: -60px;
            left: -50px;
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 40px;
            position: relative;
            z-index: 1;
        }

        .brand-logo-icon {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .brand-logo-text {
            font-size: 24px;
            font-weight: 800;
            color: #fff;
        }

        /* Animated headline — swaps based on active tab */
        .brand-headline {
            font-size: 28px;
            font-weight: 800;
            color: #fff;
            line-height: 1.3;
            margin-bottom: 14px;
            position: relative;
            z-index: 1;
            transition: opacity 0.3s, transform 0.3s;
        }

        .brand-sub {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.78);
            line-height: 1.65;
            max-width: 320px;
            margin-bottom: 36px;
            position: relative;
            z-index: 1;
            transition: opacity 0.3s;
        }

        .brand-features {
            display: flex;
            flex-direction: column;
            gap: 14px;
            position: relative;
            z-index: 1;
        }

        .brand-feature {
            display: flex;
            align-items: center;
            gap: 12px;
            color: rgba(255, 255, 255, 0.88);
            font-size: 13.5px;
        }

        .brand-feat-icon {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.14);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        /* Deco circles */
        .brand-deco {
            position: absolute;
            bottom: 30px;
            right: 30px;
            opacity: 0.10;
            z-index: 0;
        }

        /* ── Right form panel ── */
        .auth-form-panel {
            display: flex;
            flex-direction: column;
            padding: 0;
            overflow: hidden;
        }

        /* Tab switcher */
        .auth-tabs {
            display: grid;
            grid-template-columns: 1fr 1fr;
            border-bottom: 2px solid #f0f0f0;
        }

        .auth-tab {
            padding: 20px 0;
            text-align: center;
            font-size: 15px;
            font-weight: 600;
            color: #aaa;
            cursor: pointer;
            background: none;
            border: none;
            border-bottom: 3px solid transparent;
            margin-bottom: -2px;
            transition: color 0.2s, border-color 0.2s;
            font-family: inherit;
        }

        .auth-tab.active {
            color: #1a73e8;
            border-bottom-color: #1a73e8;
        }

        .auth-tab:hover:not(.active) {
            color: #555;
        }

        /* Form panes */
        .auth-panes {
            flex: 1;
            overflow: hidden;
            position: relative;
        }

        .auth-pane {
            display: none;
            padding: 28px 40px 32px;
            height: 100%;
            overflow-y: auto;
            animation: fadeIn 0.25s ease;
        }

        .auth-pane.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ── Social buttons ── */
        .social-btns {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .social-btn {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            border: 1.5px solid #e0e0e0;
            border-radius: 8px;
            padding: 9px 10px;
            font-size: 13px;
            font-weight: 500;
            color: #333;
            background: #fff;
            cursor: pointer;
            transition: border-color 0.15s, background 0.15s;
            font-family: inherit;
        }

        .social-btn:hover {
            border-color: #1a73e8;
            background: #f8f9ff;
        }

        /* Divider */
        .auth-divider {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 18px;
        }

        .auth-divider::before,
        .auth-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e8e8e8;
        }

        .auth-divider span {
            font-size: 12px;
            color: #bbb;
            white-space: nowrap;
        }

        /* Form field */
        .f-field {
            display: flex;
            flex-direction: column;
            gap: 5px;
            margin-bottom: 14px;
        }

        .f-field label {
            font-size: 13px;
            font-weight: 600;
            color: #333;
        }

        .f-field label span {
            color: #e53935;
            margin-left: 2px;
        }

        .f-input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

        .f-icon {
            position: absolute;
            left: 11px;
            color: #bbb;
            display: flex;
            align-items: center;
            pointer-events: none;
        }

        .f-input {
            width: 100%;
            border: 1.5px solid #e0e0e0;
            border-radius: 8px;
            padding: 10px 13px 10px 36px;
            font-size: 13.5px;
            color: #1a1a1a;
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
            font-family: inherit;
            background: #fff;
        }

        .f-input:focus {
            border-color: #1a73e8;
            box-shadow: 0 0 0 3px rgba(26, 115, 232, 0.10);
        }

        .f-input.error {
            border-color: #e53935;
        }

        .f-eye {
            position: absolute;
            right: 11px;
            background: none;
            border: none;
            cursor: pointer;
            color: #bbb;
            display: flex;
            align-items: center;
            transition: color 0.12s;
        }

        .f-eye:hover {
            color: #555;
        }

        .f-error {
            font-size: 11.5px;
            color: #e53935;
            display: none;
        }

        .f-field.has-error .f-error {
            display: block;
        }

        .f-field.has-error .f-input {
            border-color: #e53935;
        }

        /* 2-col row */
        .f-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        /* Options */
        .f-options {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 18px;
        }

        .f-check {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 13px;
            color: #555;
            cursor: pointer;
        }

        .f-check input {
            accent-color: #1a73e8;
            width: 15px;
            height: 15px;
            cursor: pointer;
        }

        .f-link {
            font-size: 13px;
            color: #1a73e8;
            transition: opacity .12s;
        }

        .f-link:hover {
            opacity: .75;
            text-decoration: underline;
        }

        /* Terms */
        .f-terms {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            font-size: 13px;
            color: #555;
            margin-bottom: 18px;
            line-height: 1.5;
        }

        .f-terms input {
            accent-color: #1a73e8;
            width: 15px;
            height: 15px;
            flex-shrink: 0;
            margin-top: 2px;
            cursor: pointer;
        }

        .f-terms a {
            color: #1a73e8;
        }

        /* Password strength */
        .pw-bar {
            height: 4px;
            border-radius: 2px;
            background: #e8e8e8;
            margin-top: 5px;
            overflow: hidden;
        }

        .pw-fill {
            height: 100%;
            border-radius: 2px;
            width: 0;
            transition: width .3s, background .3s;
        }

        .pw-lbl {
            font-size: 11px;
            color: #aaa;
            margin-top: 3px;
        }

        /* Submit button */
        .f-submit {
            width: 100%;
            background: #1a73e8;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 13px;
            font-size: 14.5px;
            font-weight: 700;
            cursor: pointer;
            font-family: inherit;
            transition: background .15s, box-shadow .15s;
            letter-spacing: 0.01em;
        }

        .f-submit:hover {
            background: #1557b0;
            box-shadow: 0 4px 14px rgba(26, 115, 232, .28);
        }

        /* Switch link */
        .f-switch {
            text-align: center;
            font-size: 13px;
            color: #888;
            margin-top: 16px;
        }

        .f-switch a {
            color: #1a73e8;
            font-weight: 600;
        }

        .f-switch a:hover {
            text-decoration: underline;
        }

        /* ── Responsive ── */
        @media (max-width: 768px) {
            .auth-card {
                grid-template-columns: 1fr;
                max-width: 460px;
            }

            .auth-brand-panel {
                display: none;
            }

            .auth-pane {
                padding: 24px 24px 28px;
            }

            .f-row {
                grid-template-columns: 1fr;
                gap: 0;
            }
        }

        @media (max-width: 480px) {
            .auth-center {
                padding: 20px 12px;
            }

            .auth-pane {
                padding: 20px 18px 24px;
            }

            .social-btns {
                flex-direction: column;
            }

            .btn-spinner {
                width: 14px;
                height: 14px;
                border: 2px solid #fff;
                border-top: 2px solid transparent;
                border-radius: 50%;
                display: inline-block;
                animation: spin 0.7s linear infinite;
                margin-left: 8px;
            }

            @keyframes spin {
                0% {
                    transform: rotate(0deg);
                }

                100% {
                    transform: rotate(360deg);
                }
            }

            .f-submit.loading {
                opacity: 0.7;
                cursor: not-allowed;
            }
        }
    </style>
</head>

<body class="auth-page">

    <!-- ═══ MAIN AUTH CARD ═══ -->
    <div class="auth-center">
        <div class="auth-card">

            <!-- ── LEFT BRAND PANEL ── -->
            <div class="auth-brand-panel" id="brandPanel">

                <div class="brand-logo">
                    <div class="brand-logo-icon">
                        <svg width="22" height="22" viewBox="0 0 20 20" fill="none">
                            <rect x="2" y="2" width="16" height="16" rx="3" fill="white" opacity="0.9" />
                            <path d="M6 8h8M6 11h5" stroke="#1a73e8" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                    </div>
                    <span class="brand-logo-text">Brand</span>
                </div>

                <h2 class="brand-headline" id="brandHeadline">Welcome back!<br>Sign in to your account</h2>
                <p class="brand-sub" id="brandSub">Access millions of products from verified suppliers worldwide. Manage
                    orders, track shipments and connect with sellers easily.</p>

                <div class="brand-features" id="brandFeatures">
                    <div class="brand-feature">
                        <div class="brand-feat-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                            </svg>
                        </div>
                        <span id="feat1">Verified suppliers &amp; secure transactions</span>
                    </div>
                    <div class="brand-feature">
                        <div class="brand-feat-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                                <rect x="1" y="3" width="15" height="13" rx="1" />
                                <path d="M16 8l5 3v5h-5V8z" />
                            </svg>
                        </div>
                        <span id="feat2">Worldwide shipping to 190+ countries</span>
                    </div>
                    <div class="brand-feature">
                        <div class="brand-feat-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                                <line x1="12" y1="1" x2="12" y2="23" />
                                <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" />
                            </svg>
                        </div>
                        <span id="feat3">Competitive bulk pricing &amp; discounts</span>
                    </div>
                    <div class="brand-feature">
                        <div class="brand-feat-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
                            </svg>
                        </div>
                        <span id="feat4">24/7 customer support &amp; live chat</span>
                    </div>
                </div>

                <!-- Deco -->
                <div class="brand-deco">
                    <svg width="260" height="220" viewBox="0 0 260 220" fill="none">
                        <circle cx="130" cy="110" r="100" stroke="white" stroke-width="1" />
                        <circle cx="130" cy="110" r="65" stroke="white" stroke-width="1" />
                        <circle cx="130" cy="110" r="30" fill="white" opacity="0.08" />
                        <path d="M70 110 L130 50 L190 110 L130 170 Z" stroke="white" stroke-width="1" fill="none" />
                    </svg>
                </div>
            </div>

            <!-- ── RIGHT FORM PANEL ── -->
            <div class="auth-form-panel">

                <!-- Tab switcher -->
                <div class="auth-tabs">
                    <button class="auth-tab active" id="tabLogin" onclick="switchTab('login')">Sign In</button>
                    <button class="auth-tab" id="tabRegister" onclick="switchTab('register')">Create Account</button>
                </div>

                <!-- ══════════════════════════
             LOGIN PANE
        ══════════════════════════════ -->
                <div class="auth-panes">
                    <div class="auth-pane active" id="paneLogin">

                        <div class="social-btns">
                            <button class="social-btn" type="button">
                                <svg width="18" height="18" viewBox="0 0 24 24">
                                    <path
                                        d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                                        fill="#4285F4" />
                                    <path
                                        d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                                        fill="#34A853" />
                                    <path
                                        d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                                        fill="#FBBC05" />
                                    <path
                                        d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                                        fill="#EA4335" />
                                </svg>
                                Google
                            </button>
                            <button class="social-btn" type="button">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2">
                                    <path
                                        d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                                </svg>
                                Facebook
                            </button>
                            <button class="social-btn" type="button">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                    <path
                                        d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
                                        fill="#000" />
                                </svg>
                                Apple
                            </button>
                        </div>

                        <div class="auth-divider"><span>or continue with email</span></div>

                        <form id="loginForm" onsubmit="return validateLogin(event)">

                            <div class="f-field" id="lf-email">
                                <label for="lEmail">Email address <span>*</span></label>
                                <div class="f-input-wrap">
                                    <span class="f-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="1.8">
                                            <path
                                                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                            <polyline points="22,6 12,13 2,6" />
                                        </svg></span>
                                    <input type="email" id="lEmail" name="email" class="f-input"
                                        placeholder="you@example.com" />
                                </div>
                                <span class="f-error">Please enter a valid email address.</span>
                            </div>

                            <div class="f-field" id="lf-password">
                                <label for="lPassword">Password <span>*</span></label>
                                <div class="f-input-wrap">
                                    <span class="f-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="1.8">
                                            <rect x="3" y="11" width="18" height="11" rx="2" />
                                            <path d="M7 11V7a5 5 0 0110 0v4" />
                                        </svg></span>
                                    <input type="password" id="lPassword" name="password" class="f-input"
                                        placeholder="Enter your password" />
                                    <button type="button" class="f-eye" onclick="togglePw('lPassword',this)">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="1.8">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                            <circle cx="12" cy="12" r="3" />
                                        </svg>
                                    </button>
                                </div>
                                <span class="f-error">Password must be at least 6 characters.</span>
                            </div>

                            <div class="f-options">
                                <label class="f-check">
                                    <input type="checkbox" name="remember" checked /> Remember me
                                </label>
                                <a href="#" class="f-link">Forgot password?</a>
                            </div>

                            <button type="submit" class="f-submit" id="loginSubmitBtn">Sign In</button>
                        </form>

                        <p class="f-switch">Don't have an account? <a href="javascript:void(0)"
                                onclick="switchTab('register')">Create one free</a></p>
                    </div>

                    <!-- ══════════════════════════
               REGISTER PANE
          ══════════════════════════════ -->
                    <div class="auth-pane" id="paneRegister">

                        <div class="social-btns">
                            <button class="social-btn" type="button">
                                <svg width="18" height="18" viewBox="0 0 24 24">
                                    <path
                                        d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                                        fill="#4285F4" />
                                    <path
                                        d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                                        fill="#34A853" />
                                    <path
                                        d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                                        fill="#FBBC05" />
                                    <path
                                        d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                                        fill="#EA4335" />
                                </svg>
                                Google
                            </button>
                            <button class="social-btn" type="button">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2">
                                    <path
                                        d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                                </svg>
                                Facebook
                            </button>
                            <button class="social-btn" type="button">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                    <path
                                        d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
                                        fill="#000" />
                                </svg>
                                Apple
                            </button>
                        </div>

                        <div class="auth-divider"><span>or register with email</span></div>

                        <form id="registerForm" action="/user/signup" method="POST"
                            onsubmit="return validateRegister(event)">

                            <div class="f-row">
                                <div class="f-field" id="rf-fname">
                                    <label for="rFname">First name <span>*</span></label>
                                    <div class="f-input-wrap">
                                        <span class="f-icon"></span>
                                        <input type="text" id="rFname" name="firstName" class="f-input"
                                            placeholder="John" />
                                    </div>
                                    <span class="f-error">Required.</span>
                                </div>

                                <div class="f-field" id="rf-lname">
                                    <label for="rLname">Last name <span>*</span></label>
                                    <div class="f-input-wrap">
                                        <span class="f-icon"></span>
                                        <input type="text" id="rLname" name="lastName" class="f-input"
                                            placeholder="Doe" />
                                    </div>
                                    <span class="f-error">Required.</span>
                                </div>
                            </div>

                            <div class="f-field" id="rf-email">
                                <label>Email address <span>*</span></label>
                                <div class="f-input-wrap">
                                    <span class="f-icon"></span>
                                    <input type="email" id="rEmail" name="email" class="f-input"
                                        placeholder="you@example.com" />
                                </div>
                                <span class="f-error">Please enter a valid email.</span>
                            </div>

                            <div class="f-field" id="rf-password">
                                <label>Password <span>*</span></label>
                                <div class="f-input-wrap">
                                    <span class="f-icon"></span>
                                    <input type="password" id="rPassword" name="password" class="f-input"
                                        placeholder="Create password" />
                                </div>
                                <span class="f-error">Min 8 characters.</span>
                            </div>

                            <!-- confirm password (NOT sent to backend) -->
                            <div class="f-field" id="rf-confirm">
                                <label>Confirm password <span>*</span></label>
                                <div class="f-input-wrap">
                                    <span class="f-icon"></span>
                                    <input type="password" id="rConfirm" class="f-input"
                                        placeholder="Repeat password" />
                                </div>
                                <span class="f-error">Passwords do not match.</span>
                            </div>

                            <label class="f-terms">
                                <input type="checkbox" id="rTerms" />
                                I agree to Terms & Conditions
                            </label>

                            <button type="submit" class="f-submit" id="registerSubmitBtn">
                                <span class="btn-text">Create Account</span>
                                <span class="btn-spinner" style="display:none;"></span>
                            </button>
                        </form>

                        <p class="f-switch">Already have an account? <a href="javascript:void(0)"
                                onclick="switchTab('login')">Sign in</a></p>
                    </div>
                </div><!-- /auth-panes -->

            </div><!-- /auth-form-panel -->
        </div><!-- /auth-card -->
    </div><!-- /auth-center -->



    <script>
        /* ─── Brand copy per tab ─── */
        const brandCopy = {
            login: {
                headline: 'Welcome back!<br>Sign in to your account',
                sub: 'Access millions of products from verified suppliers worldwide. Manage orders, track shipments and connect with sellers easily.',
                features: [
                    'Verified suppliers &amp; secure transactions',
                    'Worldwide shipping to 190+ countries',
                    'Competitive bulk pricing &amp; discounts',
                    '24/7 customer support &amp; live chat'
                ]
            },
            register: {
                headline: 'Join millions of<br>global buyers today',
                sub: 'Create your free account and start sourcing from verified suppliers. No hidden fees, competitive prices and full buyer protection.',
                features: [
                    'Free account — no credit card required',
                    'Access suppliers in 190+ countries',
                    'Send quotes &amp; manage orders easily',
                    'Buyer protection on every order'
                ]
            }
        };

        function switchTab(tab) {
            /* tabs */
            document.getElementById('tabLogin').classList.toggle('active', tab === 'login');
            document.getElementById('tabRegister').classList.toggle('active', tab === 'register');
            /* panes */
            document.getElementById('paneLogin').classList.toggle('active', tab === 'login');
            document.getElementById('paneRegister').classList.toggle('active', tab === 'register');
            /* brand panel */
            const copy = brandCopy[tab];
            document.getElementById('brandHeadline').innerHTML = copy.headline;
            document.getElementById('brandSub').textContent = copy.sub;
            ['feat1', 'feat2', 'feat3', 'feat4'].forEach((id, i) => {
                document.getElementById(id).innerHTML = copy.features[i];
            });
        }

        /* ─── Toggle password visibility ─── */
        const eyeOpen = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`;
        const eyeClosed = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`;

        function togglePw(inputId, btn) {
            const inp = document.getElementById(inputId);
            const isText = inp.type === 'text';
            inp.type = isText ? 'password' : 'text';
            btn.innerHTML = isText ? eyeOpen : eyeClosed;
        }

        /* ─── Password strength ─── */
        function checkStrength(val) {
            const fill = document.getElementById('pwFill');
            const lbl = document.getElementById('pwLbl');
            let score = 0;
            if (val.length >= 8) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;
            const levels = [
                { w: '0%', c: '#e0e0e0', t: 'Enter a password' },
                { w: '25%', c: '#e53935', t: 'Weak' },
                { w: '50%', c: '#fb8c00', t: 'Fair' },
                { w: '75%', c: '#fdd835', t: 'Good' },
                { w: '100%', c: '#43a047', t: 'Strong ✓' }
            ];
            const lvl = val.length === 0 ? levels[0] : levels[Math.min(score, 4)];
            fill.style.width = lvl.w;
            fill.style.background = lvl.c;
            lbl.textContent = lvl.t;
            lbl.style.color = lvl.c;
        }

        /* ─── Validation helpers ─── */
        function clearField(id) { document.getElementById(id).classList.remove('has-error'); }
        function markError(id) { document.getElementById(id).classList.add('has-error'); }
        function val(id) { return document.getElementById(id).value.trim(); }
        const isEmail = v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);

        /* ─── Login validation ─── */
async function validateLogin(e) {
    e.preventDefault();

    const btn = document.getElementById("loginSubmitBtn");

    btn.disabled = true;
    btn.innerHTML = `Signing In...`;

    const payload = {
        email: document.getElementById("lEmail").value,
        password: document.getElementById("lPassword").value
    };

    try {

        const res = await fetch("/user/signIn", {
            method: "POST",
            body: JSON.stringify(payload),
            headers: { "Content-Type": "application/json" }
        });

        const result = await res.json();

        if (res.ok) {

            // لو السيرفر بيرجع redirect
            if (result.redirect) {
                window.location.href = result.redirect;
                return;
            }

            // fallback
            window.location.href = "/";

        } else {
            showToast(result.message || "Login failed", "error");
        }

    } catch (error) {
        showToast("Something went wrong", "error");
    }

    btn.disabled = false;
    btn.innerHTML = `Sign In`;
}

        /* ─── Read URL param to open correct tab ─── */
        const urlTab = new URLSearchParams(window.location.search).get('tab');
        if (urlTab === 'register') switchTab('register');
        function setLoading(btn, isLoading) {
            const text = btn.querySelector(".btn-text");
            const spinner = btn.querySelector(".btn-spinner");

            if (isLoading) {
                btn.classList.add("loading");
                btn.disabled = true;
                text.textContent = "Creating account...";
                spinner.style.display = "inline-block";
            } else {
                btn.classList.remove("loading");
                btn.disabled = false;
                text.textContent = "Create Account";
                spinner.style.display = "none";
            }
        }
    </script>

</body>

</html>